# ─────────────────────────────────────────────────────────────────
# Bucky Brain — Docker 3-PC 환경 설정 템플릿
# ─────────────────────────────────────────────────────────────────
# 사용법:
#   python scripts/docker_sync.py --setup   # 자동 생성 (권장)
#   또는 이 파일을 docker/.env 로 복사 후 직접 편집
#
# PC_TYPE 값: home | office | laptop
# ─────────────────────────────────────────────────────────────────

# ── PC 식별 ─────────────────────────────────────────────────────
PC_TYPE=home

# ── 경로 설정 (PC_TYPE에 맞게 수정) ────────────────────────────
#   집 PC   : VAULT_BASE_PATH=G:/내 드라이브/obsidian-agent-brain-system/ObsidianVault
#   노트북  : VAULT_BASE_PATH=G:/내 드라이브/obsidian-agent-brain-system/ObsidianVault
#   사무실  : VAULT_BASE_PATH=G:/내 드라이브/obsidian-agent-brain-system/ObsidianVault
VAULT_BASE_PATH=G:/내 드라이브/obsidian-agent-brain-system/ObsidianVault

#   집 PC   : LOCAL_AI_PATH=D:/ai프로젝트
#   노트북  : LOCAL_AI_PATH=C:/ai프로젝트
#   사무실  : LOCAL_AI_PATH=C:/ai프로젝트
LOCAL_AI_PATH=D:/ai프로젝트

# G드라이브 공유 경로 (3개 PC 모두 동일)
GDRIVE_PATH=G:/내 드라이브

# ── API 키 (값을 직접 입력하세요 — 절대 커밋 금지) ─────────────
DISCORD_BOT_TOKEN=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# ── Discord 알림 Webhook (선택) ──────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── 지식 정제기 설정 ─────────────────────────────────────────────
DISTILLER_BATCH_SIZE=3
DISTILLER_RETRY_MAX=3
DISTILLER_INTERVAL_HOURS=6

# ── Redis (AgentBus 상태 공유, 선택) ────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 로그 레벨 ───────────────────────────────────────────────────
LOG_LEVEL=INFO
