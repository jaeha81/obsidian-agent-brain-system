# ═══════════════════════════════════════════════════════
# Bucky Brain System — Docker 환경변수 템플릿
# 복사: cp docker/.env.example docker/.env
# .env 는 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.
# ═══════════════════════════════════════════════════════

# ───────────────────────────────
# PC 식별 (자동 설정: docker_sync.py --setup 사용 권장)
# ───────────────────────────────
# home   → 집 PC  (D:\ai프로젝트)
# laptop → 노트북 (C:\ai프로젝트, whoami=info)
# office → 사무실 (C:\ai프로젝트, whoami=설계4)
PC_ENV=home

# ───────────────────────────────
# 경로 설정 (forward slash 사용, 끝 슬래시 없음)
# ───────────────────────────────
# 집 PC
VAULT_BASE_PATH=G:/내 드라이브/obsidian-agent-brain-system/ObsidianVault
LOCAL_AI_PATH=D:/ai프로젝트
GDRIVE_PATH=G:/내 드라이브

# 노트북 / 사무실 PC 사용 시 아래로 교체:
# LOCAL_AI_PATH=C:/ai프로젝트

# ───────────────────────────────
# API 키 (절대 하드코딩 금지)
# ───────────────────────────────
ANTHROPIC_API_KEY=
DISCORD_BOT_TOKEN=
GITHUB_TOKEN=

# ───────────────────────────────
# Discord 알림 (선택)
# ───────────────────────────────
DISCORD_WEBHOOK_URL=

# ───────────────────────────────
# 지식 정제기 설정
# ───────────────────────────────
DISTILLER_BATCH_SIZE=3
DISTILLER_RETRY_MAX=3
DISTILLER_INTERVAL_HOURS=6

# ───────────────────────────────
# Redis (AgentBus 상태 공유, 선택)
# ───────────────────────────────
REDIS_URL=redis://redis:6379/0

# ───────────────────────────────
# 로그 레벨 (DEBUG | INFO | WARNING | ERROR)
# ───────────────────────────────
LOG_LEVEL=INFO
