# Discord Bot (Bucky 구독 전용 — API 과금 없음)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
DISCORD_MIN_LENGTH=1
BUCKY_ENABLED=1
VOICE_ENABLED=1
WHISPER_MODEL=small
# BUCKY_SYSTEM_PROMPT=커스텀 시스템 프롬프트 (기본값 사용 권장)
# 사용자 접근제어: configs/discord_users.yaml (없으면 채널 내 전체 허용)

# Obsidian Vault path (absolute) — 한글 경로는 dotenv 파싱 문제로 생략 권장
# VAULT_PATH=G:\내 드라이브\obsidian-agent-brain-system\ObsidianVault

# Bucky Agent runtime (Claude Code CLI 구독 모드)
AGENT_RUNTIME=claude_cli
CLAUDE_COMMAND=claude.cmd
CLAUDE_OUTPUT_FORMAT=text
CLAUDE_USE_API_KEY=0
BUCKY_TIMEOUT=900

# Codex (독립 검수 에이전트)
CODEX_REVIEW_ENABLED=1
CODEX_COMMAND=codex
CODEX_SANDBOX=read-only
CODEX_REVIEW_INTERVAL=10
CODEX_TIMEOUT=900
CODEX_MAX_PROMPT_CHARS=24000

# 에이전트 이름 (outbox 폴더명으로 사용됨)
AGENTBUS_WORKER_NAME=Bucky

# Harness Router
HARNESS_ROUTER_ENABLED=1

# JH 공유 경로
JH_SHARED_PATH=G:\내 드라이브\JH-SHARED
JH_AGENT_ROOM_PATH=G:\내 드라이브\JH-Agent-Room

# Obsidian Local REST API (obsidian-local-rest-api 플러그인)
# 미설정 시 직접 파일 읽기로 폴백
OBSIDIAN_API_PORT=27123
OBSIDIAN_API_KEY=your_obsidian_api_key_here

# Agent Dispatcher
DISPATCHER_POLL_INTERVAL=5

# LLM Wiki 자동 생성 (raw_text / document_review / voice_transcript / video_transcript)
WIKI_AUTOWRITE_ENABLED=1

# YouTube URL 흡수 (yt-dlp 설치 필요: pip install yt-dlp)
# RAW_IMPORT/에 .url 파일 또는 YouTube URL 포함 .txt 파일 투입 시 자동 전사
RAW_WATCHER_INTERVAL=10

# Docker / 3-PC preflight
# Keep Obsidian, Claude Code, and Codex login sessions on the host by default.
DOCKER_AGENT_MODE=hybrid
