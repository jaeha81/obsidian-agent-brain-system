# =========================================
# AgentBus / Discord Bot — Environment Template
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
# =========================================

# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
# Comma-separated channel IDs to monitor (leave empty to watch ALL channels)
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
# Minimum message length to save (shorter messages are ignored)
DISCORD_MIN_LENGTH=10

# Obsidian Vault path (absolute)
VAULT_PATH=G:\내 드라이브\obsidian-agent-brain-system\ObsidianVault
