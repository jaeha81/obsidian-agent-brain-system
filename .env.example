# Discord Bot (Bucky 구독 전용 — API 과금 없음)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
DISCORD_MIN_LENGTH=1
BUCKY_ENABLED=1
VOICE_ENABLED=1
WHISPER_MODEL=small
# BUCKY_SYSTEM_PROMPT=커스텀 시스템 프롬프트 (기본값 사용 권장)
# 사용자 접근제어: configs/discord_users.yaml (없으면 채널 내 전체 허용)

# Obsidian Vault path (absolute) — 한글 경로는 dotenv 파싱 문제로 생략 권장
# VAULT_PATH=G:\내 드라이브\obsidian-agent-brain-system\ObsidianVault

# Bucky Agent runtime (Claude Code CLI 구독 모드)
AGENT_RUNTIME=claude_cli
CLAUDE_COMMAND=claude.cmd
CLAUDE_OUTPUT_FORMAT=text
CLAUDE_USE_API_KEY=0
BUCKY_TIMEOUT=900

# Codex (독립 검수 에이전트)
CODEX_REVIEW_ENABLED=1
CODEX_COMMAND=codex
CODEX_SANDBOX=read-only
CODEX_REVIEW_INTERVAL=10
CODEX_TIMEOUT=900
CODEX_MAX_PROMPT_CHARS=24000

# 에이전트 이름 (outbox 폴더명으로 사용됨)
AGENTBUS_WORKER_NAME=Bucky

# Harness Router
HARNESS_ROUTER_ENABLED=1

# JH 공유 경로
JH_SHARED_PATH=G:\내 드라이브\JH-SHARED
JH_AGENT_ROOM_PATH=G:\내 드라이브\JH-Agent-Room

# Obsidian Local REST API (obsidian-local-rest-api 플러그인)
# 미설정 시 직접 파일 읽기로 폴백
OBSIDIAN_API_PORT=27123
OBSIDIAN_API_KEY=your_obsidian_api_key_here

# Agent Dispatcher
DISPATCHER_POLL_INTERVAL=5

# LLM Wiki 자동 생성 (raw_text / document_review / voice_transcript / video_transcript)
WIKI_AUTOWRITE_ENABLED=1

# YouTube URL 흡수 (yt-dlp 설치 필요: pip install yt-dlp)
# RAW_IMPORT/에 .url 파일 또는 YouTube URL 포함 .txt 파일 투입 시 자동 전사
RAW_WATCHER_INTERVAL=10

# Wishket 자동화 (공고 스캔 + 제안서 생성)
WISHKET_EMAIL=your_wishket_email@naver.com
WISHKET_PASSWORD=your_wishket_password
# 네이버 메일 IMAP (Wishket 이메일 공고 수집)
# 설정: 네이버 메일 → 환경설정 → POP3/IMAP 설정 → IMAP 사용함 체크
#       NAVER_EMAIL: 아이디@naver.com 형식
#       NAVER_PASSWORD: 네이버 로그인 비밀번호 (앱 비밀번호 불필요)
NAVER_EMAIL=your_id@naver.com
NAVER_PASSWORD=your_naver_password

# Docker / 3-PC preflight
# Keep Obsidian, Claude Code, and Codex login sessions on the host by default.
DOCKER_AGENT_MODE=hybrid

# Multi-PC identity guard
# Home PC is the only primary writer. Office/laptop should stay secondary.
PC_NAME=unknown
PC_ROLE=secondary
LOCAL_STAGING_PATH=C:\ai-projects\staging\obsidian-agent-brain-system

# Local completion alarm
WORK_DONE_ALARM_ENABLED=1

# Daily Briefing 자동 스케줄 (AUTO_BRIEFING=1 설정 시 매일 지정 시각 자동 발송)
AUTO_BRIEFING=0
BRIEFING_CHANNEL_ID=your_channel_id_here
BRIEFING_TIME=09:00

# 멀티태스크 워커풀 (Phase 1 — 다중 작업 병렬 실행)
BUCKY_STATUS_CHANNEL_ID=   # #bucky-status 채널 ID — 미설정 시 봇 시작 시 자동 생성
WORKER_POOL_SIZE=5                                # 최대 동시 실행 태스크 수 (기본 5)

# 작업 채널 — 채널 = 독립 Claude Code 인스턴스 (tools 허용, 진짜 병렬 실행)
# Discord에서 #jh-work-1, #jh-work-2 등 채널 생성 후 ID 입력
# 각 채널에서 보낸 메시지는 별도 claude --dangerously-skip-permissions 프로세스로 실행됨
JH_WORK_CHANNEL_IDS=work_channel_id_1,work_channel_id_2
# 채널별 커스텀 시스템 프롬프트 (선택, 기본값은 코드/파일 작업 전용 프롬프트)
# JH_WORK_PROMPT_<channel_id>=너는 건축 견적 전문가다. 공종 분류 기준으로 답변한다.

# 음성 채널 설정
VOICE_CHANNEL_ENABLED=1   # 음성 채널 입/퇴장 및 TTS 기능
TTS_LANG=ko               # TTS 언어 (ko/en/ja)
VOICE_RECV_ENABLED=1      # 실시간 음성 수신 (discord-ext-voice-recv 필요)
# 봇 시작 시 자동 입장할 음성 채널 ID (선택 — Discord 채널 ID 복사 후 입력)
# AUTO_JOIN_VOICE_CHANNEL_ID=123456789012345678
# 음성 인식 결과를 전송할 텍스트 채널 (생략 시 JH_CHAT_CHANNEL_ID 사용)
# AUTO_JOIN_TEXT_CHANNEL_ID=123456789012345678
# Node.js discord_voice_capture.js 연동 채널 ID (선택)
# DISCORD_VOICE_CHANNEL_ID=123456789012345678

# Vision 이미지 분석 설정 (discord 이미지 첨부파일 OCR/분석)
# 우선순위: Claude Vision > Gemini Vision > OpenAI Vision > Tesseract OCR > URL 저장만
# ANTHROPIC_API_KEY=sk-ant-...   # Claude Vision 사용 시 (claude-opus-4-7) — 유료
# GEMINI_API_KEY=AIza...         # Gemini Vision 사용 시 (gemini-2.0-flash) — 무료 1500req/day
#                                  발급: https://aistudio.google.com/apikey
#                                  설치: pip install google-generativeai pillow
# OPENAI_API_KEY=sk-...          # OpenAI Vision 사용 시 (gpt-4o) — 유료
