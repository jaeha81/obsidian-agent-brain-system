# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
DISCORD_MIN_LENGTH=1

# Obsidian Vault path (absolute) — 한글 경로는 dotenv 파싱 문제로 생략 권장
# VAULT_PATH=G:\내 드라이브\obsidian-agent-brain-system\ObsidianVault

# Claude AI (실시간 대화용)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_SYSTEM_PROMPT=당신은 Obsidian 지식 관리 시스템과 연결된 AI 에이전트입니다.

# Obsidian Local REST API (obsidian-local-rest-api 플러그인)
# 미설정 시 직접 파일 읽기로 폴백
OBSIDIAN_API_PORT=27123
OBSIDIAN_API_KEY=your_obsidian_api_key_here

# Agent Dispatcher
DISPATCHER_POLL_INTERVAL=5