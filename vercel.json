{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "docs",
  "redirects": [
    { "source": "/index.html",                  "destination": "/repo/",        "permanent": true },
    { "source": "/wishket.html",                "destination": "/wishket/",     "permanent": true },
    { "source": "/daily-plus.html",             "destination": "/daily-plus/",  "permanent": true },
    { "source": "/task-board.html",             "destination": "/task-board/",  "permanent": true },
    { "source": "/app-session.html",            "destination": "/claude-code/", "permanent": true },
    { "source": "/kmong.html",                  "destination": "/kmong/",       "permanent": true },
    { "source": "/charlie-system-audit.html",   "destination": "/charlie/",     "permanent": true },
    { "source": "/system-workflow.html",        "destination": "/workflow/",    "permanent": true }
  ],
  "rewrites": [
    { "source": "/bucky-daily.html", "destination": "/api/protected?page=bucky-daily" },
    { "source": "/investment-report.html", "destination": "/api/protected?page=investment-report" },
    { "source": "/wishket-protected.html", "destination": "/api/protected?page=wishket" }
  ],
  "headers": [
    {
      "source": "/bucky-os.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/bucky-agent-os.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/project-graph.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/task-board/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/daily-plus/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/ai-usage.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/workflow/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "functions": {
    "api/protected.js": {
      "includeFiles": "protected/**"
    }
  }
}
