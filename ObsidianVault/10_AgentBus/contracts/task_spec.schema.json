{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bucky-os/contracts/task_spec.schema.json",
  "title": "TaskSpec",
  "description": "Bucky OS V3 태스크 서식. task_id·priority는 oracle 큐(oracle/core/api_server.py)와 호환 — 충돌 시 oracle 정본. Python 구현: scripts/core/task_spec.py",
  "type": "object",
  "required": ["task_id", "task_type"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task_\\d{8}_\\d{6}_[0-9a-f]{4}$",
      "description": "oracle new_task_id 형식: task_{YYYYMMDD_HHMMSS}_{hex4}"
    },
    "task_type": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "default": "api" },
    "channel": { "type": "string", "default": "" },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high"],
      "default": "normal"
    },
    "required_capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "constraints": { "type": "object", "default": {} },
    "expected_output": { "type": "string", "default": "" },
    "created_at": { "type": "string", "description": "ISO8601 UTC 초 단위" }
  }
}
